{
  "name": "argot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": ["cli"],
  "scripts": {
    "argot": "bun cli/src/cli.ts",
    "lint": "oxlint cli/src",
    "format": "oxfmt cli/src",
    "typecheck": "tsgo --noEmit -p cli/tsconfig.json",
    "boundaries": "depcruise cli/src",
    "knip": "knip",
    "ncu": "ncu",
    "verify": "bun run lint && bun run typecheck && bun run boundaries && bun run knip"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "dependency-cruiser": "17.3.10",
    "knip": "6.4.1",
    "npm-check-updates": "21.0.2",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "typescript": "5.9.3"
  }
}
